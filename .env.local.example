# ============================================================
# Supabase
# ============================================================
# Supabase プロジェクトダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# サーバーAPI（/api/public/company-brand 等）で m_settings を未ログイン読み取りする場合に推奨
# Dashboard > Settings > API > service_role （絶対にクライアントに出さないこと）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# LINE Login
# ============================================================
# LINE Developers > LINE Login チャネル > チャネルID
NEXT_PUBLIC_LINE_LOGIN_CHANNEL_ID=1234567890

# 本番サイトのオリジン（内部URL・PC版追客通知フォールバック用）
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# 追客「担当者へ通知」の LINE Flex 内リンク先（スマホ版・LIFF の URL）。未設定なら上記 APP_URL と同じ扱い
NEXT_PUBLIC_MOBILE_APP_URL=https://your-mobile-app.vercel.app

# LINE Login のコールバックURL（Vercel デプロイ URL に合わせること）
NEXT_PUBLIC_LINE_LOGIN_CALLBACK_URL=https://your-app.vercel.app/callback

# ============================================================
# Google Maps（Geocoding 住所→緯度経度変換 用）
# ============================================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...


# ============================================================
# LINE Messaging API（案件登録時の担当者・管理者への通知）
# ============================================================
# LINE Developers → Messaging API チャンネル → チャンネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
# LINE Developers → Messaging API チャンネル → チャンネルシークレット
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

OPENAI_API_KEY=sk-proj-xxxxxxxxxx
